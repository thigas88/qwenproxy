PORT=3000
API_KEY=your_proxy_api_key
QWEN_EMAIL=your_email@example.com
QWEN_PASSWORD=your_password

# Set to 'true' to bypass account rotation and use only guest mode (no login required)
QWEN_GUEST_MODE_ONLY=false

# Timeouts (milliseconds) — increase for slow connections
# NAVIGATION_TIMEOUT: page navigation (default: 45000)
# PAGE_TIMEOUT: waitForSelector for UI elements (default: 30000)
# HTTP_TIMEOUT: API requests and browser fetch (default: 30000)
# HEADERS_TIMEOUT: header interception during request trigger (default: 60000)
# CHAT_TIMEOUT: streaming response timeout (default: 120000)
# NAVIGATION_TIMEOUT=45000
# PAGE_TIMEOUT=30000
# HTTP_TIMEOUT=30000
# HEADERS_TIMEOUT=60000
# CHAT_TIMEOUT=120000
